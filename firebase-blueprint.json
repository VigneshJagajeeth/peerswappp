{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "bio": { "type": "string" },
        "joinedDate": { "type": "string" },
        "points": { "type": "number" },
        "averageRating": { "type": "number" },
        "totalReviews": { "type": "number" },
        "isAccountVerified": { "type": "boolean" }
      },
      "required": ["id", "name", "email", "points"]
    },
    "Listing": {
      "title": "Listing",
      "description": "A marketplace listing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "listingType": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "paymentType": { "type": "string" },
        "pointsPrice": { "type": "number" },
        "skillPrice": { "type": "string" },
        "user": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "avatarUrl": { "type": "string" }
          }
        },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "title", "description", "listingType", "paymentType", "user", "createdAt"]
    },
    "ListingRequest": {
      "title": "Listing Request",
      "description": "A request to buy/rent/swap a listing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "listingId": { "type": "string" },
        "listingTitle": { "type": "string" },
        "requesterId": { "type": "string" },
        "requesterName": { "type": "string" },
        "requesterAvatarUrl": { "type": "string" },
        "ownerId": { "type": "string" },
        "status": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "listingId", "requesterId", "ownerId", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profiles"
    },
    "/listings/{listingId}": {
      "schema": { "$ref": "#/entities/Listing" },
      "description": "Marketplace listings"
    },
    "/requests/{requestId}": {
      "schema": { "$ref": "#/entities/ListingRequest" },
      "description": "Requests between users"
    }
  }
}
